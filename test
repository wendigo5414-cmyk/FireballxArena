local Players = game:GetService("Players")
local GuiService = game:GetService("GuiService")
local VirtualInputManager = game:GetService("VirtualInputManager")

local playerGui = Players.LocalPlayer:WaitForChild("PlayerGui")
local skipButton = playerGui:WaitForChild("Rebirth")
                            :WaitForChild("Main")
                            :WaitForChild("Rebirth")
                            :WaitForChild("Contents")
                            :WaitForChild("Buttons")
                            :WaitForChild("SkipRebirthButton")
                            :WaitForChild("Btn_Skip")

if skipButton then
    print("[Direct Method] Button ko internal target kiya ja raha hai...")

    -- Step 1: Roblox Selection system me is button ko select karwana
    local oldSelection = GuiService.SelectedObject
    GuiService.SelectedObject = skipButton
    
    task.wait(0.02) -- Chota sa micro-delay engine ko register karne ke liye

    -- Step 2: Roblox UI engine ko direct 'UI Selection Click' input bhejna
    -- (Ye screen coordinates use nahi karta, direct SelectedObject par fire hota hai)
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Return, false, game) -- UI Enter Down
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Return, false, game) -- UI Enter Up

    -- Step 3: Purani selection wapas restore karna taaki user UI glitch na ho
    GuiService.SelectedObject = oldSelection
    
    print("[Direct Method] Success! Bina screen touch kiye button trigger ho gaya.")
else
    warn("Button nahi mila, path check karo.")
end
