-- Cooldown System (15 Minutes)
local COOLDOWN_TIME = 15 * 60
local COOLDOWN_FILE = "PrimeX_Feedback_Cooldown.txt"

local function getCooldown()
    if isfile and readfile and isfile(COOLDOWN_FILE) then
        local lastTime = tonumber(readfile(COOLDOWN_FILE))
        if lastTime then
            local timePassed = os.time() - lastTime
            if timePassed < COOLDOWN_TIME then
                return COOLDOWN_TIME - timePassed
            end
        end
    end
    return 0
end

local function setCooldown()
    if writefile then
        writefile(COOLDOWN_FILE, tostring(os.time()))
    end
end

-- Check Cooldown before opening
local currentCooldown = getCooldown()
if currentCooldown > 0 then
    local mins = math.ceil(currentCooldown / 60)
    -- If they have a notification system, we could use it, but we'll just use a simple message or warn
    warn("Feedback is on cooldown. Please wait " .. mins .. " minutes.")
    
    -- Try to use WindUI Notify if it exists in the environment
    pcall(function()
        if getgenv().WindUI then
            getgenv().WindUI:Notify({
                Title = "Cooldown Active",
                Content = "Please wait " .. mins .. " minutes before sending another feedback.",
                Duration = 5
            })
        end
    end)
    return
end

