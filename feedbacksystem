local function RequestAccess(options)
    if syn and syn.request then return syn.request(options) end
    if http and http.request then return http.request(options) end
    if request then return request(options) end
    return nil
end

local lastMessageCount = 0

local function addMessage(data)
    local isAdmin = (data.sender == "admin")
    
    local MsgContainer = Instance.new("Frame")
    MsgContainer.BackgroundTransparency = 1
    MsgContainer.Size = UDim2.new(1, 0, 0, 0)
    MsgContainer.AutomaticSize = Enum.AutomaticSize.Y
    MsgContainer.Parent = ChatScroll
    
    local Bubble = Instance.new("Frame")
    Bubble.BackgroundColor3 = isAdmin and Color3.fromRGB(234, 88, 12) or Color3.fromRGB(39, 39, 42)
    Bubble.AutomaticSize = Enum.AutomaticSize.XY
    Bubble.Parent = MsgContainer
    local BubbleCorner = Instance.new("UICorner")
    BubbleCorner.CornerRadius = UDim.new(0, 12)
    -- remove bottom corner depending on sender
    if isAdmin then
        local BottomRightSquare = Instance.new("Frame")
        BottomRightSquare.BackgroundColor3 = Color3.fromRGB(234, 88, 12)
        BottomRightSquare.BorderSizePixel = 0
        BottomRightSquare.Size = UDim2.new(0, 12, 0, 12)
        BottomRightSquare.Position = UDim2.new(0, 0, 1, -12)
        BottomRightSquare.Parent = Bubble
    else
        local BottomRightSquare = Instance.new("Frame")
        BottomRightSquare.BackgroundColor3 = Color3.fromRGB(39, 39, 42)
        BottomRightSquare.BorderSizePixel = 0
        BottomRightSquare.Size = UDim2.new(0, 12, 0, 12)
        BottomRightSquare.Position = UDim2.new(1, -12, 1, -12)
        BottomRightSquare.Parent = Bubble
    end
    BubbleCorner.Parent = Bubble
    
    local BubblePadding = Instance.new("UIPadding")
    BubblePadding.Parent = Bubble
    BubblePadding.PaddingTop = UDim.new(0, 10)
    BubblePadding.PaddingBottom = UDim.new(0, 10)
    BubblePadding.PaddingLeft = UDim.new(0, 15)
    BubblePadding.PaddingRight = UDim.new(0, 15)
    
    local Txt = Instance.new("TextLabel")
    Txt.BackgroundTransparency = 1
    Txt.Size = UDim2.new(0, 0, 0, 0)
    Txt.AutomaticSize = Enum.AutomaticSize.XY
    Txt.Font = Enum.Font.Gotham
    Txt.Text = data.text
    Txt.TextColor3 = isAdmin and Color3.fromRGB(255,255,255) or Color3.fromRGB(228, 228, 231)
    Txt.TextSize = 14
    Txt.TextWrapped = true
    Txt.Parent = Bubble
    
    -- Constraint text size
    local constraint = Instance.new("UITextSizeConstraint")
    constraint.MaxTextSize = 14
    constraint.Parent = Txt
    local uisizetxt = Instance.new("UISizeConstraint")
    uisizetxt.MaxSize = Vector2.new(350, 9999)
    uisizetxt.Parent = Txt
    
    -- Alignment
    if isAdmin then
        local uiList = Instance.new("UIListLayout")
        uiList.Parent = MsgContainer
        uiList.HorizontalAlignment = Enum.HorizontalAlignment.Left
    else
        local uiList = Instance.new("UIListLayout")
        uiList.Parent = MsgContainer
        uiList.HorizontalAlignment = Enum.HorizontalAlignment.Right
    end
end

local isFetching = false
local function fetchMessages()
    if isFetching then return end
    isFetching = true
    task.spawn(function()
        pcall(function()
            local res = RequestAccess({
                Url = API_URL .. "/api/chat?hwid=" .. HWID,
                Method = "GET"
            })
            if res and res.StatusCode == 200 then
                local msgs = HttpService:JSONDecode(res.Body)
                if #msgs > lastMessageCount then
                    for i = lastMessageCount + 1, #msgs do
                        addMessage(msgs[i])
                    end
                    lastMessageCount = #msgs
                    -- Scroll down
                    task.wait(0.1)
                    if not minimized then
                        ChatScroll.CanvasPosition = Vector2.new(0, 99999)
                    end
                end
            end
            
            local statusRes = RequestAccess({
                Url = API_URL .. "/api/chat/status?hwid=" .. HWID,
                Method = "GET"
            })
            if statusRes and statusRes.StatusCode == 200 then
                local st = HttpService:JSONDecode(statusRes.Body)
                if st.adminOnline then
                    TweenService:Create(StatusDot, TweenInfo.new(0.5), {BackgroundColor3 = Color3.fromRGB(16, 185, 129)}):Play()
                    StatusText.Text = "ONLINE"
                    StatusText.TextColor3 = Color3.fromRGB(16, 185, 129)
                else
                    TweenService:Create(StatusDot, TweenInfo.new(0.5), {BackgroundColor3 = Color3.fromRGB(63, 63, 70)}):Play()
                    StatusText.Text = "OFFLINE"
                    StatusText.TextColor3 = Color3.fromRGB(161, 161, 170)
                end
            end
        end)
        isFetching = false
    end)
end

-- Force initial fetch
fetchMessages()

-- Refresh Loop
task.spawn(function()
    while SupportUI.Parent do
        fetchMessages()
        task.wait(3)
    end
end)

local isSending = false
SendBtn.MouseButton1Click:Connect(function()
    if isSending then return end
    local text = TextBox.Text
    if text:gsub("%s+", "") == "" then return end
    
    isSending = true
    TextBox.Text = ""
    SendBtn.Text = "..."
    
    task.spawn(function()
        pcall(function()
            local gameName = "Unknown Game"
            pcall(function() gameName = game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name end)
            
            local payload = {
                hwid = HWID,
                displayName = LocalPlayer.Name,
                text = "Game: " .. gameName .. "\nFeedback:\n" .. text,
                type = "text"
            }
            
            RequestAccess({
                Url = API_URL .. "/api/chat",
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode(payload)
            })
            
            fetchMessages()
        end)
        isSending = false
        SendBtn.Text = "SEND"
    end)
end)

-- Draggable
local dragging
local dragInput
local dragStart
local startPos

Topbar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

Topbar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
